# ─── Copy this to .env.local and fill in values ───────────────────────────────
# .env.local is gitignored — never commit real credentials

# ── Vercel DB backend (lightweight — records, feedback, audit) ─────────────────
NEXT_PUBLIC_API_URL=https://your-vercel-backend.vercel.app

# ── ML backends (heavy — /inspect endpoint with torch + YOLO) ─────────────────
# Primary: EC2 t3.large (fast, used during judging — stop after 30 days)
ML_PRIMARY_URL=http://your-ec2-ip:8000
# Fallback: HuggingFace Spaces (free, permanent, auto-used when EC2 is off)
ML_FALLBACK_URL=https://anjani2016-weld-inspector.hf.space

# ── AWS credentials ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=weld-inspections

# Option A: Vercel Marketplace OIDC (recommended for production)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/vercel-weld-role

# Option B: Static IAM keys (local dev only — never commit!)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
